# ============================================================
#  Resource BCA — Environment Variables
#  Copy this file to ".env" and fill in the real values.
#  NEVER commit the real .env file to git.
# ============================================================

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- Supabase ----
# Find these in your Supabase project: Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
# The "anon" public key (safe for the browser, used for public reads)
SUPABASE_ANON_KEY=your-anon-public-key
# The "service_role" secret key (SERVER ONLY — full access, bypasses RLS).
# Keep this secret. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Name of the Storage bucket that holds the uploaded PDFs.
# Create a PUBLIC bucket with this name in Supabase > Storage.
SUPABASE_BUCKET=resources

# ---- Admin login (single admin) ----
ADMIN_USERNAME=admin
# Use a strong password. This is compared on login.
ADMIN_PASSWORD=choose-a-strong-password

# ---- Auth session ----
# A long random string used to sign login session tokens (JWT).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
# How long an admin stays logged in.
SESSION_DURATION=8h

# ---- Email / Nodemailer (Support Form) ----
# A Gmail account used to send support queries in the background.
SMTP_USER=your_email@gmail.com
# Google App Password (16-characters, generated in Google Account Security).
# DO NOT use your normal Gmail password here.
SMTP_PASS=your-16-character-app-password
